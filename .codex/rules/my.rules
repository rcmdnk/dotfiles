prefix_rule(
  pattern=["git", ["add", "commit", "diff"]],
  decision="allow",
)

prefix_rule(
  pattern=["uv", "run"],
  decision="allow",
)

prefix_rule(
  pattern=["pre-commit"],
  decision="allow",
)

prefix_rule(
  pattern=["prek"],
  decision="allow",
)

prefix_rule(
  pattern=["terraform", ["init", "plan", "validate"]],
  decision="allow",
)

prefix_rule(
  pattern=["uvx"],
  decision="allow",
)
