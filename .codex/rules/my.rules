prefix_rule(
  pattern=["git", ["add", "commit", "diff"]],
  decision="allow",
  match=[
    "git add .",
    "git commit -m 'message'",
    "git diff",
  ],
  not_match=[
    "git push",
    "git pull",
  ]
)

prefix_rule(
  pattern=["uv", "run"],
  decision="allow",
)

prefix_rule(
  pattern=["pre-commit"],
  decision="allow",
)

prefix_rule(
  pattern=["prek"],
  decision="allow",
)

prefix_rule(
  pattern=["terraform", ["init", "plan", "validate", "import", "state"]],
  decision="allow",
)

prefix_rule(
  pattern=["uvx"],
  decision="allow",
)

prefix_rule(
  pattern=["aws"],
  decision="allow",
)

prefix_rule(
  pattern=["marp"],
  decision="allow",
)

prefix_rule(
  pattern=["mise"],
  decision="allow",
)
