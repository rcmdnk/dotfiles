{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {},
  "permissions": {
    "allow": [
      "Bash(uv run python:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run prek:*)",
      "Bash(uv run pre-commit:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)",
      "Read(~/.bashrc)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(git reset --hard)"
    ],
    "defaultMode": "auto"
  },
  "prefersReducedMotion": true,
  "autoUpdates": true,
  "terminalProgressBarEnabled": false,
  "skipAutoPermissionPrompt": true
}
